/////////////////////////////////////////////////////////////////////////////
//
// Dialog
//

ID_form1 DIALOG DISCARDABLE  200, 100, 360, 220
STYLE WS_MINIMIZEBOX | WS_MAXIMIZEBOX | WS_POPUP | WS_CAPTION | WS_SYSMENU | 
    WS_THICKFRAME
CAPTION "我的记事本"
FONT 9, "����"
BEGIN
    EDITTEXT        ID_txtMain,7,7,346,206,ES_LEFT | ES_MULTILINE | ES_AUTOVSCROLL | 
                    ES_AUTOHSCROLL | WS_VSCROLL | WS_HSCROLL
END

ID_frmInputEnc DIALOG DISCARDABLE  0, 0, 240, 96
STYLE DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "输入加密密码"
FONT 9, "����"
BEGIN
    LTEXT           "请输入文件加密/解密密码（留空表示不加密，仅教学演示）",IDC_STATIC,8,8,224,18
    EDITTEXT        ID_txtEnc,8,30,224,14,ES_PASSWORD | ES_AUTOHSCROLL
    DEFPUSHBUTTON   "确定",ID_cmdOK,88,70,60,14
    PUSHBUTTON      "取消",ID_cmdCancel,164,70,60,14
END

IDR_MENU_MAIN MENU DISCARDABLE 
BEGIN
    POPUP "文件(&F)"
    BEGIN
        MENUITEM "新建(&N)",                    ID_mnuFileNew
        MENUITEM "打开...(&O)",                 ID_mnuFileOpen
        MENUITEM "保存(&S)",                    ID_mnuFileSave
        MENUITEM "另存为...(&A)",               ID_mnuFileSaveAs
        MENUITEM SEPARATOR
        MENUITEM "退出(&X)",                    ID_mnuFileExit
    END
    POPUP "编辑(&E)"
    BEGIN
        MENUITEM "剪切(&T)",                    ID_mnuEditCut
        MENUITEM "复制(&C)",                    ID_mnuEditCopy
        MENUITEM "粘贴(&P)",                    ID_mnuEditPaste
        MENUITEM "删除(&D)",                    ID_mnuEditDelete
        MENUITEM SEPARATOR
        MENUITEM "全选(&A)",                    ID_mnuEditSelectAll
        MENUITEM "时间/日期(&W)",               ID_mnuEditTimeDate
    END
    POPUP "帮助(&H)"
    BEGIN
        MENUITEM "半透明窗体(&T)",               ID_mnuViewOpacity
        MENUITEM "挖空白色区域(&K)",             ID_mnuViewPunchWhite
        MENUITEM "恢复正常显示(&R)",             ID_mnuViewNormal
        MENUITEM SEPARATOR
        MENUITEM "创新点...(&I)",               ID_mnuHelpInnovation
    END
END


